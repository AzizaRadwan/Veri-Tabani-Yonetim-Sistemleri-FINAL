    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE alerts\nSET \n    alert_status = 'sent',\n    sent_at = GETDATE()\nWHERE alert_id = {{$json.alert_id}};\n\nINSERT INTO workflow_logs (\n    workflow_name,\n    email_id,\n    execution_status,\n    log_message\n)\nVALUES (\n    '06 - Alert Notification',\n    {{$json.email_id}},\n    'success',\n    'Pending alert notification prepared and marked as sent by n8n workflow.'\n);",
