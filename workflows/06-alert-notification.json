    {
      "parameters": {
        "jsCode": "const alert = $json;\n\nconst notificationMessage = `\nMAILSENSE AI ALERT\n\nAlert ID: ${alert.alert_id}\nEmail ID: ${alert.email_id}\nRisk ID: ${alert.risk_id}\nMessage: ${alert.alert_message}\nCreated At: ${alert.created_at}\n\nAction Required:\nPlease review the related email and take necessary action.\n`;\n\nreturn [\n  {\n    json: {\n      alert_id: alert.alert_id,\n      email_id: alert.email_id,\n      notification_message: notificationMessage\n    }\n  }\n];"
      },
